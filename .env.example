# OpenPrompter — Environment Configuration
# API keys are primarily configured through the in-app BYOK dialog
# (persisted to localStorage). Server-side env vars are optional.

# Server port (default: 3000)
PORT=3000

# Set to "production" for strict CSP (no unsafe-inline/eval)
NODE_ENV=production

# Bind address (default: 127.0.0.1). Use 0.0.0.0 for Docker/cloud.
BIND_HOST=127.0.0.1

# Public URL for self-referential links
APP_URL="http://localhost:3000"
